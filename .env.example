# DocVault Environment Variables
# Copy to .env and fill in values. Never commit .env.
# chmod 600 .env after creation

# PostgreSQL connection string
DOCVAULT_DATABASE_URL=postgresql://docvault:changeme@localhost:5432/docvault

# 32-byte random hex key for AES-256-GCM webhook secret encryption
# Generate with: openssl rand -hex 32
DOCVAULT_AUTH_SECRET_KEY=

# Fastify bind address (do not change unless behind a proxy you trust)
DOCVAULT_SERVER_HOST=127.0.0.1
DOCVAULT_SERVER_PORT=3000
DOCVAULT_PUBLIC_URL=

# Log level: trace|debug|info|warn|error
DOCVAULT_SERVER_LOG_LEVEL=info

# Python embedding worker HTTP endpoint
DOCVAULT_WORKER_URL=http://127.0.0.1:8001

# Optional shared bearer token between the API and the worker. When set (on BOTH
# sides), the worker's /embed and /snippet endpoints require this token.
# Leave blank if the worker port is only reachable by the local API process;
# strongly recommended otherwise. Generate with: openssl rand -hex 32
DOCVAULT_WORKER_TOKEN=
# Max embedding request body the worker will accept, in MB (default 16).
DOCVAULT_WORKER_MAX_REQUEST_MB=16

# Embedding device: auto | cuda | cpu
#   auto — picks CUDA if available, CPU otherwise (recommended default)
#   cuda — requires an NVIDIA GPU with CUDA; falls back to CPU if not found
#   cpu  — always use CPU (slower indexing, but fully functional)
DOCVAULT_EMBEDDING_DEVICE=auto
DOCVAULT_EMBEDDING_MODEL_PATH=~/.cache/docvault/models

# Optional outbound notification relay.
# When set, approval/comment events are POSTed here (e.g. to a bot orchestrator
# that routes them to the creating agent). Leave blank to disable notifications.
#   DOCVAULT_NOTIFY_WEBHOOK_URL   — destination URL
#   DOCVAULT_NOTIFY_WEBHOOK_TOKEN — optional bearer token sent with each delivery
DOCVAULT_NOTIFY_WEBHOOK_URL=
DOCVAULT_NOTIFY_WEBHOOK_TOKEN=


# Node environment
NODE_ENV=production
